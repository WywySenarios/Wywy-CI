# Wywy-CI Frontend Configuration
# ===============================
# These PUBLIC_* variables are exposed to client-side code by Astro.
# During development, the Astro dev server (port 3001) needs absolute
# URLs to reach the Go API server (port 2526 by default).
#
# In production the Astro build is embedded in the Go binary and served
# on the same origin, so these are only needed when running separately.
#
# CI_PORT is registered in /etc/Wywy-Website-Control/config/.env.network.

PUBLIC_CI_API_HOST=localhost
PUBLIC_CI_API_PORT=2526
